# Neon pooled endpoint 사용 (호스트에 -pooler 포함)
# postgresql+asyncpg://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?ssl=require

# 마이그레이션 전용 (Alembic은 동기 드라이버 사용). pooled 말고 direct endpoint 권장.
# postgresql+psycopg://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL_SYNC=postgresql+psycopg://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require

CORS_ORIGINS=http://localhost:5173
